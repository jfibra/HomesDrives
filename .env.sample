# Safe example environment file for sharing with AI/tools.
# Replace placeholder values in .env only.

# Supabase project configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Storage bucket configuration
SUPABASE_STORAGE_BUCKET=your-bucket-name

# Supabase Storage S3-compatible credentials
# These work with AWS SDKs when the endpoint points to Supabase Storage.
AWS_ACCESS_KEY_ID=your-supabase-s3-access-key
AWS_SECRET_ACCESS_KEY=your-supabase-s3-secret-key
AWS_REGION=your-s3-region
AWS_S3_BUCKET=your-bucket-name
AWS_S3_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3

# Optional app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
