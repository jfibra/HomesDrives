# Safe example environment file for sharing with AI/tools.
# Replace placeholder values in .env only.

# Supabase project configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Storage bucket configuration
SUPABASE_STORAGE_BUCKET=your-bucket-name

# Supabase Storage S3-compatible credentials
# These work with AWS SDKs when the endpoint points to Supabase Storage.
# Use the S3 endpoint and access keys generated from Supabase Storage.
# Uploaded objects will be stored inside: AWS_S3_BUCKET/homesph/...
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_PREFIX=homesph
AWS_S3_ENDPOINT=

# InsightFace face recognition service (People feature)
INSIGHTFACE_API_URL=http://127.0.0.1:8000
FACE_MATCH_THRESHOLD=0.45
# Min gap between top two matches before merging (reduces mixing different people).
FACE_MATCH_MARGIN=0.08

# AI Reels Maker — EC2 worker (like InsightFace). See services/reels-api/README.md
# Vercel UI calls EC2 directly for uploads/video (avoids Vercel body-size limits).
# NEXT_PUBLIC_REELS_API_URL=http://YOUR_EC2_PUBLIC_IP:8001
# REELS_API_URL=http://YOUR_EC2_PUBLIC_IP:8001
# REELS_API_SECRET=generate-a-long-random-secret
# REELS_API_ALLOWED_ORIGINS=https://drive.homes.ph,https://your-app.vercel.app
# REELS_API_PORT=8001
# FFMPEG_PATH=/usr/bin/ffmpeg

# Building recognition API (partner sites call drive.homes.ph/api/buildings)
# BUILDING_API_KEY=generate-a-long-random-secret
# BUILDING_API_ALLOWED_ORIGINS=https://homes.ph,https://www.homes.ph,https://drive.homes.ph
# BUILDING_MATCH_THRESHOLD=0.78
# BUILDING_MATCH_DB_THRESHOLD=0.65
# BUILDING_MATCH_MIN_MARGIN=0.04
# BUILDING_HIGH_CONFIDENCE_THRESHOLD=0.85
# BUILDING_GPS_RADIUS_KM=3

# LocationIQ reverse geocoding
LOCATIONIQ_API_KEY=your-locationiq-api-key

# Google Maps API key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Gemini AI (poster generation + reels maker on EC2)
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_REELS_MODEL=gemini-2.0-flash

# Drive app URL (e.g. https://drive.homes.ph) — metadata and profile pages.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Main homes.ph origin for category form links and QR codes (always https://homes.ph in production).
NEXT_PUBLIC_HOMES_FORM_ORIGIN=https://homes.ph

# Hostinger SMTP (media registration emails)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=drive@homes.ph
SMTP_PASS=your-smtp-password
SMTP_FROM="Homes.ph Drive" <drive@homes.ph>
